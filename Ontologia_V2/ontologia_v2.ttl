#################################################################
#    Object Properties
#################################################################

###  urn:absolute:www.sbc.upc.edu/viatges#Ciudad
:Ciudad rdf:type owl:ObjectProperty .


###  urn:absolute:www.sbc.upc.edu/viatges#Transporte
:Transporte rdf:type owl:ObjectProperty .


###  urn:absolute:www.sbc.upc.edu/viatges#Usuario
:Usuario rdf:type owl:ObjectProperty .


###  urn:absolute:www.sbc.upc.edu/viatges#Viaje
:Viaje rdf:type owl:ObjectProperty .


###  urn:absolute:www.sbc.upc.edu/viatges#conectaCon
:conectaCon rdf:type owl:ObjectProperty ;
            rdfs:subPropertyOf :Ciudad ;
            rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> ;
            rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> .


###  urn:absolute:www.sbc.upc.edu/viatges#duermeEn
:duermeEn rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :Viaje .


###  urn:absolute:www.sbc.upc.edu/viatges#incluyeCiudad
:incluyeCiudad rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :Viaje ;
               rdfs:domain :Viaje ;
               rdfs:range :CiudadCandidata .


###  urn:absolute:www.sbc.upc.edu/viatges#incluyePI
:incluyePI rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :Viaje ;
           rdfs:domain :Viaje ;
           rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#PuntoDeInteres> .


###  urn:absolute:www.sbc.upc.edu/viatges#recibeViaje
:recibeViaje rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :Usuario ;
             rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Usuario> ;
             rdfs:range :Viaje .


###  urn:absolute:www.sbc.upc.edu/viatges#tieneAlojamiento
:tieneAlojamiento rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :Ciudad ;
                  rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> ;
                  rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Alojamiento> .


###  urn:absolute:www.sbc.upc.edu/viatges#tieneFin
:tieneFin rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :Transporte ;
          rdf:type owl:FunctionalProperty ;
          rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Transporte> ;
          rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> .


###  urn:absolute:www.sbc.upc.edu/viatges#tieneOrigen
:tieneOrigen rdf:type owl:ObjectProperty ;
             rdfs:subPropertyOf :Transporte ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Transporte> ;
             rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> .


###  urn:absolute:www.sbc.upc.edu/viatges#tienePOI
:tienePOI rdf:type owl:ObjectProperty ;
          rdfs:subPropertyOf :Ciudad ;
          rdfs:domain <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#Ciudad> ;
          rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#PuntoDeInteres> .


###  urn:absolute:www.sbc.upc.edu/viatges#tieneTema
:tieneTema rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf :Viaje ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Viaje ;
           rdfs:range <http://www.semanticweb.org/moval/ontologies/2026/4/untitled-ontology-5#TematicaViaje> .


###  urn:absolute:www.sbc.upc.edu/viatges#viajaCon
:viajaCon rdf:type owl:ObjectProperty ;
